@model IEnumerable<HuongDanLamDep.Models.Comment>
@using System.Linq

@{
    ViewData["Title"] = "Bình luận";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="comment-page-header mb-4">
    <div>
        <h1 class="comment-page-title">Bình luận</h1>
        <p class="comment-page-subtitle">Quản lý các bình luận được gửi từ phía người dùng</p>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="card shadow-sm border-0 comments-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table comments-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 150px;">Thời gian</th>
                            <th style="width: 220px;">Người gửi</th>
                            <th style="width: 200px;">Tên bài viết</th>
                            <th>Nội dung</th>
                            <th style="width: 130px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="comment-time-date">
                                        @item.CreatedAt.ToString("dd/MM/yyyy")
                                    </div>
                                    <div class="comment-time-hour">
                                        @item.CreatedAt.ToString("HH:mm")
                                    </div>
                                </td>

                                <td>
                                    <span class="comment-user-badge">
                                        @(string.IsNullOrWhiteSpace(item.UserName) ? "Người dùng" : item.UserName)
                                    </span>
                                </td>

                                <td>
                                    <div class="comment-tutorial-title">
                                        @(item.Tutorial?.Title ?? "Không có bài viết")
                                    </div>
                                </td>

                                <td>
                                    <div class="comment-content-box">
                                        @item.Content
                                    </div>
                                </td>

                                <td>
                                    <form asp-area="Admin"
                                          asp-controller="Comments"
                                          asp-action="Delete"
                                          asp-route-id="@item.CommentId"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-danger btn-sm delete-comment-btn"
                                                onclick="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">
                                            Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info shadow-sm border-0 mt-3">
        Chưa có bình luận nào để hiển thị.
    </div>
}
