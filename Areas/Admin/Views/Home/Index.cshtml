@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Dashboard</h3>
        <div class="text-muted">Tổng quan hệ thống quản trị</div>
    </div>
    <div class="d-flex gap-2">
        Tổng quan số liệu
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted">Categories</div>
                <div class="display-6 fw-semibold">@ViewBag.CategoryCount</div>
                Xem danh sách vào Category </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted">Tutorials</div>
                <div class="display-6 fw-semibold">@ViewBag.TutorialCount</div>
                Xem danh sách vào Tutorial</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted">Bình luận</div>
                <div class="display-6 fw-semibold">@ViewBag.CommentCount</div>
                
                Xem danh sách vào Comments
                </a>
        </div>
    </div>
</div>

<hr class="my-4" />

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-2">Báo cáo</h5>
        <div class="text-muted mb-3">Xuất báo cáo các bài viết file PDF ở Categories.</div>
    </div>
</div>