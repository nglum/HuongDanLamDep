@model IEnumerable<HuongDanLamDep.Models.Tutorial>

@{
    ViewData["Title"] = "Index";
}

<h1>Quản lý bài viết</h1>

<form method="get" class="mb-3">
    <input name="search" value="@ViewBag.Search" placeholder="Tìm theo tiêu đề..." />
    <button type="submit">Tìm</button>
</form>

<p>
    <a asp-action="Create">Tạo bài viết mới</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Content)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td style="white-space: pre-line; max-width: 350px; word-break: break-word;">
                    @item.Content
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TutorialId">Sửa bài viết</a> 
                <a asp-action="Details" asp-route-id="@item.TutorialId">Chi tiết bài viết</a> 
                    <a asp-action="ExportPdf" asp-route-id="@item.TutorialId">Xuất file PDF</a>
                <a asp-action="Delete" asp-route-id="@item.TutorialId">Xóa bài viết</a>
            </td>
        </tr>
}
    </tbody>
</table>
@{
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string search = ViewBag.Search as string ?? "";
}

<div class="mt-3">
    @if (currentPage > 1)
    {
        <a asp-area="Admin"
           asp-controller="Tutorials"
           asp-action="Index"
           asp-route-search="@search"
           asp-route-page="@(currentPage - 1)">« Prev</a>
    }

    <span style="margin:0 10px;">Trang @currentPage / @totalPages</span>

    @if (currentPage < totalPages)
    {
        <a asp-area="Admin"
           asp-controller="Tutorials"
           asp-action="Index"
           asp-route-search="@search"
           asp-route-page="@(currentPage + 1)">Next »</a>
    }
</div>