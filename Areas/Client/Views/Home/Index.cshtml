@model HuongDanLamDep.ViewModels.ClientHomeVM
@using HuongDanLamDep.Models
@using System.Linq

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var comments = ViewBag.Comments as List<Comment> ?? new List<Comment>();
}

@if (TempData["success"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success">
            @TempData["success"]
        </div>
    </div>
}

@if (TempData["error"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-danger">
            @TempData["error"]
        </div>
    </div>
}

<!-- Banner -->
<section class="py-5 bg-light border-bottom">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="fw-bold mb-3">Web Hướng Dẫn Làm Đẹp</h1>
                <p class="lead text-muted mb-4">
                    Chia sẻ các bài hướng dẫn chăm sóc da, trang điểm, chăm sóc tóc
                    và những mẹo làm đẹp đơn giản hằng ngày.
                </p>
                <a asp-area="Client" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    Khám phá ngay
                </a>
            </div>

            <div class="col-lg-5 text-center">
                <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800"
                     class="img-fluid rounded shadow-sm"
                     alt="Banner làm đẹp" />
            </div>
        </div>
    </div>
</section>

<!-- Bài viết mới nhất -->
<section class="py-5">
    <div class="container">
        <h2 class="h4 mb-4">Bài viết mới nhất</h2>

        @if (Model.LatestTutorials != null && Model.LatestTutorials.Any())
        {
            @foreach (var item in Model.LatestTutorials)
            {
                var content = item.Content ?? "";
                var shortText = content.Length > 180
                    ? content.Substring(0, 180) + "..."
                    : content;

                var previewId = $"preview_{item.TutorialId}";
                var fullId = $"full_{item.TutorialId}";
                var buttonId = $"btn_{item.TutorialId}";
                var isLoggedIn = User.Identity != null && User.Identity.IsAuthenticated;

                var tutorialComments = comments
                    .Where(c => c.TutorialId == item.TutorialId)
                    .OrderByDescending(c => c.CreatedAt)
                    .ToList();

                <article class="mb-5 pb-4 border-bottom">
                    <div class="row">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=800"
                                 class="img-fluid rounded shadow-sm"
                                 alt="Tutorial image" />
                        </div>

                        <div class="col-md-8">
                            <div class="small text-muted mb-2">
                                @(item.Category?.Name ?? "Chưa có danh mục")
                            </div>

                            <h3 class="h5 fw-bold mb-3">@item.Title</h3>

                            <!-- Nội dung rút gọn -->
                            <div id="@previewId" class="text-muted" style="white-space: pre-line; line-height: 1.8;">
                                @shortText
                            </div>

                            <!-- Nội dung đầy đủ -->
                            <div id="@fullId" class="text-muted d-none" style="white-space: pre-line; line-height: 1.8;">
                                @content
                            </div>

                            <!-- Nút xem thêm -->
                            <div class="mt-3">
                                @if (isLoggedIn)
                                {
                                    <button id="@buttonId"
                                            type="button"
                                            class="btn btn-link p-0 text-decoration-none"
                                            onclick="toggleTutorialContent('@previewId', '@fullId', '@buttonId')">
                                        Xem thêm
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-link p-0 text-decoration-none"
                                            onclick="requireLoginNotice('Bạn cần đăng nhập để xem tiếp nội dung bài viết.')">
                                        Xem thêm
                                    </button>
                                }
                            </div>

                            <!-- Ô bình luận -->
                            <div class="mt-4 p-3 rounded border bg-light">
                                <label class="form-label fw-semibold mb-2">Bình luận</label>
                                <div class="comment-message mb-2"></div>

                                @if (!isLoggedIn)
                                {
                                    <div class="small text-danger mb-2">
                                        Bạn cần đăng nhập để bình luận.
                                    </div>
                                }

                                <form action="@Url.Action("AddCommentAjax", "Tutorials", new { area = "Client" })"
                                      method="post"
                                      class="comment-form"
                                      data-tutorial-id="@item.TutorialId"
                                      onsubmit="submitComment(event, this)">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tutorialId" value="@item.TutorialId" />

                                    <div class="d-flex gap-2 align-items-start flex-column flex-sm-row">
                                        <textarea name="content"
                                          class="form-control"
                                          rows="3"
                                          placeholder="Nhập bình luận của bạn..."
                                          @(isLoggedIn ? null : "disabled")></textarea>

                                        @if (isLoggedIn)
                                        {
                                            <button type="submit" class="btn btn-primary">
                                                Gửi
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-secondary"
                                                    onclick="requireLoginNotice('Bạn cần đăng nhập để bình luận.')">
                                                Gửi
                                            </button>
                                        }
                                    </div>
                                </form>

                                <!-- Danh sách bình luận của bài viết -->
                                <div class="mt-3 comment-list" id="comment-list-@item.TutorialId">
                                    @if (tutorialComments.Any())
                                    {
                                        @foreach (var c in tutorialComments)
                                        {
                                            <div class="border rounded p-2 mb-2 bg-white">
                                                <div class="small text-muted mb-1">
                                                    @(string.IsNullOrWhiteSpace(c.UserName) ? "Người dùng" : c.UserName)
                                                    • @c.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                                <div style="white-space: pre-line;">
                                                    @c.Content
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="small text-muted empty-comment-note">
                                            Chưa có bình luận nào.
                                        </div>
                                    }
                                </div>
                            </div>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="alert alert-info">
                Chưa có bài viết nào để hiển thị.
            </div>
        }
    </div>
</section>

<!-- Danh mục làm đẹp -->
<section class="pb-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="h4 mb-0">Danh mục làm đẹp</h2>
        </div>

        <div class="row g-3">
            @if (Model.Categories != null && Model.Categories.Any())
            {
                @foreach (var item in Model.Categories)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body text-center">
                                <h5 class="card-title mb-0">@item.Name</h5>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info">
                        Chưa có danh mục nào để hiển thị.
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function toggleTutorialContent(previewId, fullId, buttonId) {
            const preview = document.getElementById(previewId);
            const full = document.getElementById(fullId);
            const button = document.getElementById(buttonId);

            const isExpanded = !full.classList.contains('d-none');

            if (!isExpanded) {
                preview.classList.add('d-none');
                full.classList.remove('d-none');
                button.innerText = 'Thu gọn';
            } else {
                full.classList.add('d-none');
                preview.classList.remove('d-none');
                button.innerText = 'Xem thêm';
            }
        }

        function requireLoginNotice(message) {
            alert(message);
        }

        async function submitComment(e, form) {
            e.preventDefault();

            const formData = new FormData(form);
            const tutorialId = form.dataset.tutorialId;
            const messageBox = form.closest(".bg-light").querySelector(".comment-message");
            const commentList = document.getElementById("comment-list-" + tutorialId);
            const textarea = form.querySelector("textarea[name='content']");

            try {
                const response = await fetch(form.action, {
                    method: "POST",
                    body: formData,
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                const contentType = response.headers.get("content-type") || "";

                if (!contentType.includes("application/json")) {
                    const text = await response.text();
                    console.error("Response không phải JSON:", text);
                    messageBox.innerHTML = '<div class="alert alert-danger py-2 mb-0">Có lỗi xảy ra khi gửi bình luận.</div>';
                    return;
                }

                const result = await response.json();

                if (result.success) {
                    messageBox.innerHTML = '<div class="alert alert-success py-2 mb-0">' + result.message + '</div>';

                    const emptyNote = commentList.querySelector(".empty-comment-note");
                    if (emptyNote) {
                        emptyNote.remove();
                    }

                    const newComment = document.createElement("div");
                    newComment.className = "border rounded p-2 mb-2 bg-white";
                    newComment.innerHTML = `
                        <div class="small text-muted mb-1">
                            ${result.userName} • ${result.createdAt}
                        </div>
                        <div style="white-space: pre-line;">
                            ${result.content}
                        </div>
                    `;

                    commentList.prepend(newComment);
                    textarea.value = "";
                } else {
                    messageBox.innerHTML = '<div class="alert alert-danger py-2 mb-0">' + result.message + '</div>';
                }
            } catch (err) {
                console.error("Lỗi AJAX:", err);
                messageBox.innerHTML = '<div class="alert alert-danger py-2 mb-0">Có lỗi xảy ra khi gửi bình luận.</div>';
            }
        }
    </script>
}